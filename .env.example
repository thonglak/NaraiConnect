# ─── Database (shared back_db container) ─────────────────────────────────
DB_HOST=back_db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=narai_portal2

# ─── API ─────────────────────────────────────────────────────────────────
API_PORT=3100
API_PUBLIC_URL=http://localhost:3100
WEB_PUBLIC_URL=http://localhost:3001
NODE_ENV=development

# Path prefix when served behind a reverse proxy. Leave empty for dev.
# In prod set to "/sso_man" so cookies and asset URLs use the right scope.
APP_BASE_PATH=

# ─── Session ────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-32-byte-random-hex
SESSION_COOKIE_NAME=ncadm_sid
SESSION_MAX_AGE_SECONDS=28800

# ─── NaraiConnect OAuth (admin app's own client) ────────────────────────
# Insert client row in `oauth_clients` first, then put values here.
OAUTH_CLIENT_ID=replace-me
OAUTH_CLIENT_SECRET=replace-me
OAUTH_AUTHORIZE_URL=https://apps.naraiproperty.com/connect/oauth/authorize
OAUTH_TOKEN_URL=https://apps.naraiproperty.com/connect/oauth/authorize/token
OAUTH_USERINFO_URL=https://apps.naraiproperty.com/connect/oauth/resource
OAUTH_REDIRECT_URI=http://localhost:3100/api/v1/auth/callback
OAUTH_SCOPE=email

# ─── Web (SolidStart) ───────────────────────────────────────────────────
WEB_PORT=3001
VITE_API_URL=http://localhost:3100

# ─────────────────────────────────────────────────────────────────────────
# Production overrides — uncomment / replace for deploy at
# https://apps.naraiproperty.com/sso_man/
# ─────────────────────────────────────────────────────────────────────────
# NODE_ENV=production
# APP_BASE_PATH=/sso_man
# API_PUBLIC_URL=https://apps.naraiproperty.com/sso_man
# WEB_PUBLIC_URL=https://apps.naraiproperty.com/sso_man
# VITE_API_URL=https://apps.naraiproperty.com/sso_man
# OAUTH_REDIRECT_URI=https://apps.naraiproperty.com/sso_man/api/v1/auth/callback
# Insert a separate oauth_clients row with this redirect_uri (different
# client_id from the dev one) and use those credentials here.
